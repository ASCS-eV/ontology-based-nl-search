{
  "name": "@ontology-search/lsp-server",
  "version": "0.1.0",
  "description": "Standalone LSP 3.18 server for ontology-derived GraphQL query completion and validation.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ontology-search-lsp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc -p tsconfig.test.json",
    "test": "pnpm run build && vitest run",
    "clean": "rimraf dist",
    "coverage": "pnpm run build && vitest run --coverage",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@ontology-search/api-types": "workspace:*",
    "@ontology-search/graphql-ir": "workspace:*",
    "@ontology-search/typescript-config": "workspace:*",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "3.2.4",
    "esbuild": "^0.27.7",
    "graphql": "^17.0.1",
    "graphql-language-service": "5.5.2",
    "rimraf": "^6.0.0",
    "tar": "^7.5.9",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0",
    "vscode-jsonrpc": "^9.0.1",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^4.4.3"
  }
}
