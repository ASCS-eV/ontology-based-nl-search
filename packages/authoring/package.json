{
  "name": "@ontology-search/authoring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The authoring backend seam — a config-selected, swappable AuthoringBackend over the in-process OpenSCENARIO WASM engine (validate + describe), mirroring packages/sparql's SparqlStore. The rest of the codebase depends only on this interface.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./src/backend.ts",
      "import": "./dist/backend.js",
      "default": "./dist/backend.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc -p tsconfig.test.json",
    "clean": "rimraf dist",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ontology-search/authoring-ir": "workspace:*",
    "@ontology-search/authoring-wasm": "workspace:*",
    "@ontology-search/core": "workspace:*"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "3.2.4",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
