{
  "name": "@ontology-search/core",
  "description": "Foundation utilities — Zod config, structured logging, errors, RDF prefixes, SSE, and LRU cache. Zero workspace dependencies.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./logging": {
      "types": "./src/logging/index.ts",
      "import": "./dist/logging/index.js",
      "default": "./dist/logging/index.js"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "import": "./dist/errors/index.js",
      "default": "./dist/errors/index.js"
    },
    "./graphql/enum": {
      "types": "./src/graphql/enum.ts",
      "import": "./dist/graphql/enum.js",
      "default": "./dist/graphql/enum.js"
    },
    "./rdf/prefixes": {
      "types": "./src/rdf/prefixes.ts",
      "import": "./dist/rdf/prefixes.js",
      "default": "./dist/rdf/prefixes.js"
    },
    "./rdf/iri": {
      "types": "./src/rdf/iri.ts",
      "import": "./dist/rdf/iri.js",
      "default": "./dist/rdf/iri.js"
    },
    "./http/mime": {
      "types": "./src/http/mime.ts",
      "import": "./dist/http/mime.js",
      "default": "./dist/http/mime.js"
    },
    "./sse/events": {
      "types": "./src/sse/events.ts",
      "import": "./dist/sse/events.js",
      "default": "./dist/sse/events.js"
    },
    "./sse/parser": {
      "types": "./src/sse/parser.ts",
      "import": "./dist/sse/parser.js",
      "default": "./dist/sse/parser.js"
    },
    "./cache/lru": {
      "types": "./src/cache/lru.ts",
      "import": "./dist/cache/lru.js",
      "default": "./dist/cache/lru.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc -p tsconfig.test.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@zazuko/prefixes": "^2.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@types/node": "^22.19.17",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
