{
  "name": "@ontology-search/api-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTTP-boundary wire types shared between the API server and the web client. Zero workspace dependencies — browser-safe.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc -p tsconfig.test.json",
    "clean": "rimraf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
