{
  "name": "@ontology-search/llm",
  "description": "LLM interpretation layer — SHACL-grounded prompt builder, multi-provider slot-filling agent, and SHACL slot validation. The LLM never writes SPARQL.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./prompt-builder": {
      "types": "./src/prompt-builder.ts",
      "import": "./dist/prompt-builder.js",
      "default": "./dist/prompt-builder.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.68",
    "@github/copilot-sdk": "^1.0.0",
    "@ontology-search/core": "workspace:*",
    "@ontology-search/search": "workspace:*",
    "ai": "^6.0.198",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@types/node": "^25.7.0",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
