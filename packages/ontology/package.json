{
  "name": "@ontology-search/ontology",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./domain-registry": {
      "types": "./src/domain-registry.ts",
      "import": "./src/domain-registry.ts",
      "default": "./dist/domain-registry.js"
    },
    "./vocabulary-index": {
      "types": "./src/vocabulary-index.ts",
      "import": "./src/vocabulary-index.ts",
      "default": "./dist/vocabulary-index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ontology-search/core": "workspace:*"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
