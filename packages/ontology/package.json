{
  "name": "@ontology-search/ontology",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./domain-registry": {
      "types": "./src/domain-registry.ts",
      "import": "./dist/domain-registry.js",
      "default": "./dist/domain-registry.js"
    },
    "./vocabulary-index": {
      "types": "./src/vocabulary-index.ts",
      "import": "./dist/vocabulary-index.js",
      "default": "./dist/vocabulary-index.js"
    },
    "./shacl-validator": {
      "types": "./src/shacl-validator.ts",
      "import": "./dist/shacl-validator.js",
      "default": "./dist/shacl-validator.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ontology-search/core": "workspace:*",
    "@rdfjs/dataset": "^2.0.2",
    "n3": "^2.0.3",
    "rdf-validate-shacl": "^0.6.5"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^25.7.0",
    "@types/rdfjs__dataset": "^2.0.7",
    "oxigraph": "^0.4.11",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
