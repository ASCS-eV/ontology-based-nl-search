    skos:altLabel "exit lane"@en ;
    skos:altLabel "highway exit"@en ;
    skos:altLabel "Ausfahrt"@de ;
    skos:related nlsearch:offRamp ;
    skos:related nlsearch:mwyExit ;
    skos:definition "A lane leading away from the main carriageway."@en ;
    nlsearch:ontologyProperty hdmap:laneTypes ;
    nlsearch:ontologyValue "exit" .

