nlsearch:road5 a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "Road5"@en ;
    skos:altLabel "road5"@en ;
    nlsearch:ontologyProperty hdmap:formatType ;
    nlsearch:ontologyValue "Road5" .

