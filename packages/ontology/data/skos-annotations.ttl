nlsearch:emergencyLane a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "emergency"@en ;
    skos:altLabel "emergency lane"@en ;
    skos:altLabel "Rettungsgasse"@de ;
    nlsearch:ontologyProperty hdmap:laneTypes ;
