    skos:altLabel "hard shoulder"@en ;
    skos:altLabel "Standstreifen"@de ;
    nlsearch:ontologyProperty hdmap:laneTypes ;
    nlsearch:ontologyValue "shoulder" .

nlsearch:parkingLane a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "parking"@en ;
    skos:altLabel "parking lane"@en ;
    skos:altLabel "Parkstreifen"@de ;
    nlsearch:ontologyProperty hdmap:laneTypes ;
