@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/> .
@prefix scenario: <https://w3id.org/ascs-ev/envited-x/scenario/v6/> .
@prefix georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/> .
@prefix gx: <https://w3id.org/gaia-x/development#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix nlsearch: <https://w3id.org/ascs-ev/ontology-based-nl-search/concepts/> .

# ============================================================
# SKOS Concept Scheme for Natural Language Search
#
# Scientific basis: W3C SKOS (Simple Knowledge Organization System)
# provides a standard model for expressing knowledge organization
# systems. This file defines:
# - skos:prefLabel: canonical ontology value
# - skos:altLabel: known synonyms (user language variants)
# - skos:broader/narrower: hierarchical relationships
# - skos:related: associative (non-hierarchical) relationships
#
# @see https://www.w3.org/TR/skos-reference/
# ============================================================

nlsearch:ConceptScheme a skos:ConceptScheme ;
    rdfs:label "HD Map NL Search Vocabulary"@en ;
    rdfs:comment "SKOS concept scheme for mapping natural language to HD map ontology values."@en .

# ============================================================
# Road Type Concepts
# ============================================================

nlsearch:motorway a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "motorway"@en ;
    skos:altLabel "highway"@en ;
    skos:altLabel "autobahn"@de ;
    skos:altLabel "freeway"@en ;
    skos:altLabel "expressway"@en ;
    skos:altLabel "interstate"@en ;
    skos:definition "A high-speed controlled-access road for through traffic."@en ;
    nlsearch:ontologyProperty hdmap:roadTypes ;
    nlsearch:ontologyValue "motorway" .

nlsearch:rural a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "rural"@en ;
    skos:altLabel "country road"@en ;
    skos:altLabel "countryside"@en ;
    skos:altLabel "Landstraße"@de ;
    skos:definition "A road outside urban areas."@en ;
    nlsearch:ontologyProperty hdmap:roadTypes ;
    nlsearch:ontologyValue "rural" .

nlsearch:town a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "town"@en ;
    skos:altLabel "urban"@en ;
    skos:altLabel "city road"@en ;
    skos:altLabel "Stadtstraße"@de ;
    skos:definition "A road within a built-up area."@en ;
    nlsearch:ontologyProperty hdmap:roadTypes ;
    nlsearch:ontologyValue "town" .

nlsearch:townArterial a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "townArterial"@en ;
    skos:altLabel "arterial road"@en ;
    skos:altLabel "main road"@en ;
    skos:altLabel "Hauptstraße"@de ;
    skos:broader nlsearch:town ;
    nlsearch:ontologyProperty hdmap:roadTypes ;
    nlsearch:ontologyValue "townArterial" .

nlsearch:townExpressway a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "townExpressway"@en ;
    skos:altLabel "urban expressway"@en ;
    skos:altLabel "Schnellstraße"@de ;
    skos:broader nlsearch:town ;
    nlsearch:ontologyProperty hdmap:roadTypes ;
    nlsearch:ontologyValue "townExpressway" .

nlsearch:pedestrian a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "pedestrian"@en ;
    skos:altLabel "pedestrian zone"@en ;
    skos:altLabel "Fußgängerzone"@de ;
    skos:altLabel "walking area"@en ;
    nlsearch:ontologyProperty hdmap:roadTypes ;
    nlsearch:ontologyValue "pedestrian" .

nlsearch:lowSpeed a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "lowSpeed"@en ;
    skos:altLabel "low speed"@en ;
    skos:altLabel "Tempo 30"@de ;
    nlsearch:ontologyProperty hdmap:roadTypes ;
    nlsearch:ontologyValue "lowSpeed" .

# ============================================================
# Lane Type Concepts
# ============================================================

nlsearch:exitLane a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
