nlsearch:asamOpenDrive a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "ASAM OpenDRIVE"@en ;
    skos:altLabel "OpenDRIVE"@en ;
    skos:altLabel "opendrive"@en ;
    skos:altLabel "XODR"@en ;
    skos:altLabel "xodr"@en ;
    skos:definition "ASAM OpenDRIVE standard for road network description."@en ;
    nlsearch:ontologyProperty hdmap:formatType ;
    nlsearch:ontologyValue "ASAM OpenDRIVE" .

