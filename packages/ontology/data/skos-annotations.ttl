nlsearch:connectingRamp a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "connectingRamp"@en ;
    skos:altLabel "connecting ramp"@en ;
    skos:altLabel "ramp"@en ;
    skos:altLabel "Rampe"@de ;
    skos:related nlsearch:onRamp ;
    skos:related nlsearch:offRamp ;
    nlsearch:ontologyProperty hdmap:laneTypes ;
    nlsearch:ontologyValue "connectingRamp" .

