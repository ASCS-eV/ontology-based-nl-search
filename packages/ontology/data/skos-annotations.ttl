    skos:prefLabel "biking"@en ;
    skos:altLabel "bike lane"@en ;
    skos:altLabel "bicycle lane"@en ;
    skos:altLabel "cycling"@en ;
    skos:altLabel "Radweg"@de ;
    nlsearch:ontologyProperty hdmap:laneTypes ;
