nlsearch:walkingLane a skos:Concept ;
    skos:inScheme nlsearch:ConceptScheme ;
    skos:prefLabel "walking"@en ;
    skos:altLabel "sidewalk"@en ;
    skos:altLabel "pavement"@en ;
