// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`compileSlots — determinism + snapshot suite > all four geographic fields combined as ordinary filters 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
PREFIX georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/>
SELECT ?asset ?name ?city ?country ?region ?state WHERE {
  ?asset a hdmap:HdMap ;
    rdfs:label ?name .
  ?asset hdmap:hasDomainSpecification ?domSpec .
  ?domSpec hdmap:hasGeoreference ?_d0_1 .
  ?_d0_1 georeference:hasProjectLocation ?_d0_2 .
  ?_d0_2 georeference:city ?city .
  ?_d0_2 georeference:country ?country .
  ?_d0_2 georeference:region ?region .
  ?_d0_2 georeference:state ?state .
  FILTER(?city = "Munich")
  FILTER(?country = "DE")
  FILTER(?region = "Oberbayern")
  FILTER(?state = "Bavaria")
}
LIMIT 100"
`;

