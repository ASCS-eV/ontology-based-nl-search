exports[`compileSlots — determinism + snapshot suite > multiple references (ositrace + hdmap) → two AND-combined JOINs, both projected 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX scenario: <https://w3id.org/ascs-ev/envited-x/scenario/v6/>
PREFIX manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/>
PREFIX ositrace: <https://w3id.org/ascs-ev/envited-x/ositrace/v6/>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?refAsset ?refName ?ref_step_1 ?ref_step_2 ?refAsset1 ?refName1 ?ref1_step_1 ?ref1_step_2 WHERE {
  { SELECT DISTINCT ?asset WHERE {
  ?asset a scenario:Scenario ;
    rdfs:label ?name .
  ?asset scenario:hasManifest ?ref_step_1 .
  ?ref_step_1 manifest:hasReferencedArtifacts ?ref_step_2 .
  ?ref_step_2 manifest:iri ?refAsset .
  ?refAsset a ositrace:OSITrace .
  ?refAsset rdfs:label ?refName .
  ?asset scenario:hasManifest ?ref1_step_1 .
  ?ref1_step_1 manifest:hasReferencedArtifacts ?ref1_step_2 .
  ?ref1_step_2 manifest:iri ?refAsset1 .
  ?refAsset1 a hdmap:HdMap .
  ?refAsset1 rdfs:label ?refName1 .
  } LIMIT 100 }
  ?asset a scenario:Scenario ;
    rdfs:label ?name .
  ?asset scenario:hasManifest ?ref_step_1 .
  ?ref_step_1 manifest:hasReferencedArtifacts ?ref_step_2 .
  ?ref_step_2 manifest:iri ?refAsset .
  ?refAsset a ositrace:OSITrace .
  ?refAsset rdfs:label ?refName .
  ?asset scenario:hasManifest ?ref1_step_1 .
  ?ref1_step_1 manifest:hasReferencedArtifacts ?ref1_step_2 .
  ?ref1_step_2 manifest:iri ?refAsset1 .
  ?refAsset1 a hdmap:HdMap .
  ?refAsset1 rdfs:label ?refName1 .
}
LIMIT 500"
`;

exports[`compileSlots — determinism + snapshot suite > nested reference (scenario → trace → map) chains the JOIN through the trace 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX scenario: <https://w3id.org/ascs-ev/envited-x/scenario/v6/>
PREFIX manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/>
PREFIX ositrace: <https://w3id.org/ascs-ev/envited-x/ositrace/v6/>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?refAsset ?refName ?ref_step_1 ?ref_step_2 ?refAsset_0 ?refName_0 ?ref_0_step_1 ?ref_0_step_2 WHERE {
  { SELECT DISTINCT ?asset WHERE {
  ?asset a scenario:Scenario ;
    rdfs:label ?name .
  ?asset scenario:hasManifest ?ref_step_1 .
  ?ref_step_1 manifest:hasReferencedArtifacts ?ref_step_2 .
  ?ref_step_2 manifest:iri ?refAsset .
  ?refAsset a ositrace:OSITrace .
  ?refAsset rdfs:label ?refName .
  ?refAsset ositrace:hasManifest ?ref_0_step_1 .
  ?ref_0_step_1 manifest:hasReferencedArtifacts ?ref_0_step_2 .
  ?ref_0_step_2 manifest:iri ?refAsset_0 .
  ?refAsset_0 a hdmap:HdMap .
  ?refAsset_0 rdfs:label ?refName_0 .
  } LIMIT 100 }
  ?asset a scenario:Scenario ;
    rdfs:label ?name .
  ?asset scenario:hasManifest ?ref_step_1 .
  ?ref_step_1 manifest:hasReferencedArtifacts ?ref_step_2 .
  ?ref_step_2 manifest:iri ?refAsset .
  ?refAsset a ositrace:OSITrace .
  ?refAsset rdfs:label ?refName .
  ?refAsset ositrace:hasManifest ?ref_0_step_1 .
  ?ref_0_step_1 manifest:hasReferencedArtifacts ?ref_0_step_2 .
  ?ref_0_step_2 manifest:iri ?refAsset_0 .
  ?refAsset_0 a hdmap:HdMap .
  ?refAsset_0 rdfs:label ?refName_0 .
}
LIMIT 500"
`;

exports[`compileSlots — determinism + snapshot suite > peer domains (hdmap + ositrace) with country filter → UNION 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
PREFIX georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/>
PREFIX ositrace: <https://w3id.org/ascs-ev/envited-x/ositrace/v6/>
SELECT ?asset ?name ?roadTypes ?country WHERE {
    {
    ?asset a hdmap:HdMap ;
      rdfs:label ?name .
    ?asset hdmap:hasDomainSpecification ?domSpec .
    ?domSpec hdmap:hasContent ?content .
    ?content hdmap:roadTypes ?roadTypes .
    ?domSpec hdmap:hasGeoreference ?_d0_1 .
    ?_d0_1 georeference:hasProjectLocation ?_d0_2 .
    ?_d0_2 georeference:country ?country .
    FILTER(?roadTypes = "motorway")
    FILTER(?country = "FR")
  }
  UNION
  {
    ?asset a ositrace:OSITrace ;
      rdfs:label ?name .
    ?asset ositrace:hasDomainSpecification ?domSpec .
    ?domSpec ositrace:hasContent ?content .
    ?content ositrace:roadTypes ?roadTypes .
    ?domSpec ositrace:hasGeoreference ?_d0_1 .
    ?_d0_1 georeference:hasProjectLocation ?_d0_2 .
    ?_d0_2 georeference:country ?country .
    FILTER(?roadTypes = "motorway")
    FILTER(?country = "FR")
  }
}
LIMIT 100"
`;

exports[`compileSlots — determinism + snapshot suite > peer domains (hdmap + ositrace) with shared roadTypes → UNION 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
PREFIX ositrace: <https://w3id.org/ascs-ev/envited-x/ositrace/v6/>
SELECT ?asset ?name ?roadTypes WHERE {
    {
    ?asset a hdmap:HdMap ;
      rdfs:label ?name .
    ?asset hdmap:hasDomainSpecification ?domSpec .
    ?domSpec hdmap:hasContent ?content .
    ?content hdmap:roadTypes ?roadTypes .
    FILTER(?roadTypes = "motorway")
  }
  UNION
  {
    ?asset a ositrace:OSITrace ;
      rdfs:label ?name .
    ?asset ositrace:hasDomainSpecification ?domSpec .
    ?domSpec ositrace:hasContent ?content .
    ?content ositrace:roadTypes ?roadTypes .
    FILTER(?roadTypes = "motorway")
  }
}
LIMIT 100"
`;

exports[`compileSlots — determinism + snapshot suite > routes a non-legacy shape group through the discovered link predicate 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?accuracySignals WHERE {
  ?asset a hdmap:HdMap ;
    rdfs:label ?name .
  ?asset hdmap:hasDomainSpecification ?domSpec .
  ?domSpec hdmap:hasQuality ?quality .
  ?quality hdmap:accuracySignals ?accuracySignals .
  FILTER(?accuracySignals = "0.1")
}
LIMIT 100"
`;

