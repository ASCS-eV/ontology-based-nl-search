exports[`compileSlots — determinism + snapshot suite > location with all four geographic fields populated 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/>
PREFIX georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?country ?state ?region ?city WHERE {
  ?asset a hdmap:HdMap ;
    rdfs:label ?name .
  ?asset hdmap:hasDomainSpecification ?domSpec .
  ?domSpec hdmap:hasGeoreference ?georef .
  ?georef georeference:hasProjectLocation ?loc .
  ?loc georeference:country ?country .
  ?loc georeference:state ?state .
  ?loc georeference:region ?region .
  ?loc georeference:city ?city .
  FILTER(CONTAINS(LCASE(?country), "de"))
  FILTER(CONTAINS(LCASE(?state), "bavaria"))
  FILTER(CONTAINS(LCASE(?region), "oberbayern"))
  FILTER(CONTAINS(LCASE(?city), "munich"))
}
LIMIT 100"
`;

