exports[`compileSlots — determinism + snapshot suite > hdmap Format-group filter (formatType) 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?formatType WHERE {
  ?asset a hdmap:HdMap ;
    rdfs:label ?name .
  ?asset hdmap:hasDomainSpecification ?domSpec .
  ?domSpec hdmap:hasFormat ?format .
  ?format hdmap:formatType ?formatType .
  FILTER(?formatType = "ASAM OpenDRIVE")
}
LIMIT 100"
`;

