exports[`compileSlots — determinism + snapshot suite > hdmap with filter + range + country + license combined 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
PREFIX envited-x: <https://w3id.org/ascs-ev/envited-x/envited-x/v3/>
PREFIX georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/>
SELECT ?asset ?name ?roadTypes ?license ?numberIntersections ?country WHERE {
  ?asset a hdmap:HdMap ;
    rdfs:label ?name .
  ?asset hdmap:hasDomainSpecification ?domSpec .
  ?domSpec hdmap:hasContent ?content .
  ?content hdmap:roadTypes ?roadTypes .
  ?domSpec envited-x:hasQuality ?quality_envited_x .
  ?quality_envited_x envited-x:license ?license .
  ?domSpec hdmap:hasQuantity ?quantity .
  ?quantity hdmap:numberIntersections ?numberIntersections .
  ?domSpec hdmap:hasGeoreference ?_d0_1 .
  ?_d0_1 georeference:hasProjectLocation ?_d0_2 .
  ?_d0_2 georeference:country ?country .
  FILTER(?roadTypes = "motorway")
  FILTER(?license = "CC-BY-4.0")
  FILTER(xsd:float(?numberIntersections) >= 5)
  FILTER(xsd:float(?numberIntersections) <= 50)
  FILTER(?country = "DE")
}
LIMIT 100"
`;

