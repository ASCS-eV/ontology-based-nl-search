exports[`compileSlots — determinism + snapshot suite > single reference → distinct-asset-limited JOIN 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX ositrace: <https://w3id.org/ascs-ev/envited-x/ositrace/v6/>
PREFIX manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?refAsset ?refName ?ref_step_1 ?ref_step_2 WHERE {
  { SELECT DISTINCT ?asset WHERE {
  ?asset a ositrace:OSITrace ;
    rdfs:label ?name .
  ?asset ositrace:hasManifest ?ref_step_1 .
  ?ref_step_1 manifest:hasReferencedArtifacts ?ref_step_2 .
  ?ref_step_2 manifest:iri ?refAsset .
  ?refAsset a hdmap:HdMap .
  ?refAsset rdfs:label ?refName .
  } LIMIT 100 }
  ?asset a ositrace:OSITrace ;
    rdfs:label ?name .
  ?asset ositrace:hasManifest ?ref_step_1 .
  ?ref_step_1 manifest:hasReferencedArtifacts ?ref_step_2 .
  ?ref_step_2 manifest:iri ?refAsset .
  ?refAsset a hdmap:HdMap .
  ?refAsset rdfs:label ?refName .
}
LIMIT 500"
`;
