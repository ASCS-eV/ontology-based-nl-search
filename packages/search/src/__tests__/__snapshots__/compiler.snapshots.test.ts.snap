`;

exports[`compileSlots — determinism + snapshot suite > scenario + hdmap cross-domain (primary scenario references hdmap) 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/>
PREFIX georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/>
PREFIX scenario: <https://w3id.org/ascs-ev/envited-x/scenario/v6/>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?scenarioCategory ?roadTypes_hdmap WHERE {
  ?asset a scenario:Scenario ;
    rdfs:label ?name .
  ?asset scenario:hasDomainSpecification ?domSpec .
  ?domSpec scenario:hasContent ?content .
  ?content scenario:scenarioCategory ?scenarioCategory .
  ?asset scenario:hasManifest ?manifest .
  ?manifest manifest:hasReferencedArtifacts ?ref_hdmap .
  ?ref_hdmap a hdmap:HdMap .
  ?ref_hdmap hdmap:hasDomainSpecification ?refSpec_hdmap .
  ?refSpec_hdmap hdmap:hasContent ?content_hdmap .
  ?content_hdmap hdmap:roadTypes ?roadTypes_hdmap .
  FILTER(?scenarioCategory = "urban")
  FILTER(?roadTypes_hdmap = "motorway")
}
LIMIT 100"
`;

exports[`compileSlots — determinism + snapshot suite > scenario + hdmap cross-domain with range on referenced domain 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/>
PREFIX georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/>
PREFIX scenario: <https://w3id.org/ascs-ev/envited-x/scenario/v6/>
PREFIX hdmap: <https://w3id.org/ascs-ev/envited-x/hdmap/v6/>
SELECT ?asset ?name ?scenarioCategory ?numberIntersections_hdmap WHERE {
  ?asset a scenario:Scenario ;
    rdfs:label ?name .
  ?asset scenario:hasDomainSpecification ?domSpec .
  ?domSpec scenario:hasContent ?content .
  ?content scenario:scenarioCategory ?scenarioCategory .
  ?asset scenario:hasManifest ?manifest .
  ?manifest manifest:hasReferencedArtifacts ?ref_hdmap .
  ?ref_hdmap a hdmap:HdMap .
  ?ref_hdmap hdmap:hasDomainSpecification ?refSpec_hdmap .
  ?refSpec_hdmap hdmap:hasQuantity ?quantity_hdmap .
  ?quantity_hdmap hdmap:numberIntersections ?numberIntersections_hdmap .
  FILTER(?scenarioCategory = "urban")
  FILTER(xsd:float(?numberIntersections_hdmap) >= 3)
}
LIMIT 100"
`;

