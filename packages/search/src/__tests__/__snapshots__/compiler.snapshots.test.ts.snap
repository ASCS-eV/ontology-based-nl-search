exports[`compileSlots — determinism + snapshot suite > scenario single Content filter (scenarioCategory) 1`] = `
"PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gx: <https://w3id.org/gaia-x/development#>
PREFIX manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/>
PREFIX georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/>
PREFIX scenario: <https://w3id.org/ascs-ev/envited-x/scenario/v6/>
SELECT ?asset ?name ?scenarioCategory WHERE {
  ?asset a scenario:Scenario ;
    rdfs:label ?name .
  ?asset scenario:hasDomainSpecification ?domSpec .
  ?domSpec scenario:hasContent ?content .
  ?content scenario:scenarioCategory ?scenarioCategory .
  FILTER(?scenarioCategory = "urban")
}
LIMIT 100"
`;
