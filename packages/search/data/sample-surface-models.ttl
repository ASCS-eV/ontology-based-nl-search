@prefix surface-model: <https://w3id.org/ascs-ev/envited-x/surface-model/v6/> .
@prefix envited-x: <https://w3id.org/ascs-ev/envited-x/envited-x/v3/> .
@prefix georeference: <https://w3id.org/ascs-ev/envited-x/georeference/v5/> .
@prefix manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/> .
@prefix gx: <https://w3id.org/gaia-x/development#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Surface Model 1: Berlin ASAM OpenCRG Surface Model ---

<did:web:surfacepro.io:SurfaceModel:berlin-surface-001> a surface-model:SurfaceModel ;
  rdfs:label "Berlin ASAM OpenCRG Surface Model"@en ;
  surface-model:hasResourceDescription [
    a envited-x:ResourceDescription ;
    gx:name "Berlin ASAM OpenCRG Surface Model" ;
    gx:description "roughness profile for Berlin, Berlin using ASAM OpenCRG format" ;
    gx:version "2.2.0" ;
    gx:license "CC-BY-4.0" ;
    gx:containsPII false
  ] ;
  surface-model:hasDomainSpecification [
    a surface-model:DomainSpecification ;
    surface-model:hasFormat [
      a surface-model:Format ;
      surface-model:formatType "ASAM OpenCRG" ;
      surface-model:version "1.1"
    ] ;
    surface-model:hasContent [
      a surface-model:Content ;
      surface-model:contentType "roughness profile"
    ] ;
    surface-model:hasQuantity [
      a surface-model:Quantity ;
      surface-model:length "32.01"^^xsd:float ;
      surface-model:elevationRange "96.27"^^xsd:float ;
      surface-model:mapDataField true
    ] ;
    surface-model:hasQuality [
      a surface-model:Quality ;
      surface-model:resolutionLongitudinal "0.001"^^xsd:float ;
      surface-model:resolutionLateral "0.001"^^xsd:float ;
      surface-model:orientation "143.27"^^xsd:float ;
      surface-model:platformExists false ;
      surface-model:rampExists false
    ] ;
    surface-model:hasGeoreference [
      a georeference:Georeference ;
      georeference:hasProjectLocation [
        a georeference:ProjectLocation ;
        georeference:country "DE" ;
        georeference:state "DE-BE" ;
        georeference:region "Berlin" ;
        georeference:city "Berlin"
      ]
    ]
  ] ;
  surface-model:hasManifest [
    a manifest:Manifest
  ] .

