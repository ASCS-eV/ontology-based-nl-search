# --- OSI Trace 1: San Francisco town OSI Trace ---

<did:web:osidata.io:OSITrace:san-francisco-town-001> a ositrace:OSITrace ;
  rdfs:label "San Francisco town OSI Trace"@en ;
  ositrace:hasResourceDescription [
    a envited-x:ResourceDescription ;
    gx:name "San Francisco town OSI Trace" ;
    gx:description "SensorData trace of town road in San Francisco, California" ;
    gx:version "1.2.0" ;
    gx:license "CC-BY-NC-4.0" ;
    gx:containsPII false
  ] ;
  ositrace:hasDomainSpecification [
    a ositrace:DomainSpecification ;
    ositrace:hasFormat [
      a ositrace:Format ;
      ositrace:formatType "ASAM OSI SensorData" ;
      ositrace:version "3.6.0" ;
      ositrace:fileFormat "MCAP" ;
      ositrace:compression "uncompressed" ;
      ositrace:osiTraceFormatVersion "1.0.0"
    ] ;
    ositrace:hasContent [
      a ositrace:Content ;
      ositrace:roadTypes "town" ;
      ositrace:laneTypes "median" , "entry" ;
      ositrace:levelOfDetail "bike" ;
      ositrace:trafficDirection "right-hand" ;
      ositrace:granularity "detection list"
    ] ;
    ositrace:hasQuantity [
      a ositrace:Quantity ;
      ositrace:numberFrames "47862"^^xsd:integer ;
      ositrace:numberOfChannels "5"^^xsd:integer
    ] ;
    ositrace:hasQuality [
      a ositrace:Quality ;
      ositrace:precision "0.02"^^xsd:float
    ] ;
    ositrace:hasDataSource [
      a ositrace:DataSource ;
      ositrace:usedDataSources "camera" ;
      ositrace:measurementSystem "CARLA Simulator"
    ] ;
    ositrace:hasGeoreference [
      a georeference:Georeference ;
      georeference:hasProjectLocation [
        a georeference:ProjectLocation ;
        georeference:country "US" ;
        georeference:state "US-CA" ;
        georeference:region "California" ;
        georeference:city "San Francisco"
      ]
    ]
  ] ;
  ositrace:hasManifest [
    a manifest:Manifest
  ] .

