# --- Scenario 1: Cut In in Munich ---

<did:web:simcorp.io:Scenario:cut-in-munich-001> a scenario:Scenario ;
  rdfs:label "Cut In in Munich"@en ;
  scenario:hasDomainSpecification [
    a scenario:DomainSpecification ;
    scenario:hasFormat [
      a scenario:Format ;
      scenario:formatType "ASAM OpenSCENARIO" ;
      scenario:version "1.3"
    ] ;
    scenario:hasContent [
      a scenario:Content ;
      scenario:abstractionLevel "Abstract" ;
      scenario:scenarioCategory "cut-in" ;
      scenario:weatherSummary "clear" ;
      scenario:entityTypes "car" ;
      scenario:entityTypes "pedestrian" ;
      scenario:country "de"
    ] ;
    scenario:hasQuantity [
      a scenario:Quantity ;
      scenario:numberOfEntities "2"^^xsd:integer ;
      scenario:duration "5.0"^^xsd:float
    ] ;
    scenario:hasGeoreference [
      a georeference:Georeference ;
      georeference:hasProjectLocation [
        a georeference:ProjectLocation ;
        georeference:country "DE" ;
        georeference:city "Munich"
      ]
    ]
  ] ;
  scenario:hasManifest [
    a manifest:Manifest ;
    manifest:hasReferencedArtifacts <did:web:prov1.net:HdMap:ref-001>
  ] .

<did:web:prov1.net:HdMap:ref-001> a hdmap:HdMap ;
  rdfs:label "Ref HD Map for Cut In in Munich"@en ;
  hdmap:hasDomainSpecification [
    a hdmap:DomainSpecification ;
    hdmap:hasContent [
      a hdmap:Content ;
      hdmap:roadTypes "motorway" ;
      hdmap:laneTypes "driving"
    ]
  ] .

