      scenario:version "1.3"
    ] ;
    scenario:hasContent [
      a scenario:Content ;
      scenario:abstractionLevel "Abstract" ;
      scenario:scenarioCategory "cut-in" ;
      scenario:weatherSummary "clear" ;
      scenario:entityTypes "car" ;
      scenario:entityTypes "pedestrian" ;
      scenario:country "de" ;
      scenario:criticalityFactors "occlusion"
    ] ;
    scenario:hasQuantity [
      a scenario:Quantity ;
      scenario:numberTrafficObjects "2"^^xsd:integer ;
      scenario:permanentTrafficObjects "1"^^xsd:integer ;
      scenario:temporaryTrafficObjects "0"^^xsd:integer
    ] ;
    scenario:hasDataSource [
      a scenario:DataSource ;
      scenario:sourceType "Accident Database"
    ] ;
    scenario:hasGeoreference [
      a georeference:Georeference ;
      georeference:hasProjectLocation [
        a georeference:ProjectLocation ;
        georeference:country "DE" ;
        georeference:city "Munich"
      ]
    ]
  ] ;
  scenario:hasManifest [
    a manifest:Manifest ;
