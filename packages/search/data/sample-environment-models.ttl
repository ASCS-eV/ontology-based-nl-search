@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Environment Model 1: San Francisco Low Detail Environment Model ---

<did:web:envmodels.io:EnvironmentModel:san-francisco-envmodel-001> a environment-model:EnvironmentModel ;
  rdfs:label "San Francisco Low Detail Environment Model"@en ;
  environment-model:hasResourceDescription [
    a envited-x:ResourceDescription ;
    gx:name "San Francisco Low Detail Environment Model" ;
    gx:description "Low detail 3D environment model of San Francisco for digital twin" ;
    gx:version "1.3.0" ;
    gx:license "proprietary" ;
    gx:containsPII false
  ] ;
  environment-model:hasDomainSpecification [
    a environment-model:DomainSpecification ;
    environment-model:hasFormat [
      a environment-model:Format ;
      environment-model:formatType "glTF" ;
      environment-model:version "3.0"
    ] ;
    environment-model:hasContent [
      a environment-model:Content ;
      environment-model:elements "urban environment, street furniture" ;
      environment-model:useCase "digital twin"
    ] ;
    environment-model:hasProject [
      a environment-model:Project ;
      environment-model:creationToolName "CARLA Scene Builder" ;
      environment-model:creationToolVendor "CARLA" ;
      environment-model:creationToolVersion "0.9.15"
    ] ;
    environment-model:hasQuantity [
      a environment-model:Quantity ;
      environment-model:triangleCount "4588267"^^xsd:integer ;
      environment-model:geometryCount "771"^^xsd:integer ;
      environment-model:textureMaterialCount "83"^^xsd:integer
    ] ;
    environment-model:hasQuality [
      a environment-model:Quality ;
      environment-model:detailLevel "Low" ;
      environment-model:textureResolution "4096"^^xsd:float
    ] ;
    environment-model:hasGeoreference [
      a georeference:Georeference ;
      georeference:hasProjectLocation [
        a georeference:ProjectLocation ;
        georeference:country "US" ;
        georeference:state "US-CA" ;
        georeference:region "California" ;
        georeference:city "San Francisco"
      ]
    ]
  ] ;
  environment-model:hasManifest [
    a manifest:Manifest
  ] .

