{
  "name": "@ontology-search/search",
  "description": "Search core — deterministic SPARQL compiler from structured slots, graph-driven schema metadata, and query orchestration.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./slots": {
      "types": "./src/slots.ts",
      "import": "./dist/slots.js",
      "default": "./dist/slots.js"
    },
    "./compiler": {
      "types": "./src/compiler.ts",
      "import": "./dist/compiler.js",
      "default": "./dist/compiler.js"
    },
    "./sparql-validator": {
      "types": "./src/sparql-validator.ts",
      "import": "./dist/sparql-validator.js",
      "default": "./dist/sparql-validator.js"
    },
    "./shacl-reader": {
      "types": "./src/shacl-reader.ts",
      "import": "./dist/shacl-reader.js",
      "default": "./dist/shacl-reader.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./slot-wire-schema": {
      "types": "./src/slot-wire-schema.ts",
      "import": "./dist/slot-wire-schema.js",
      "default": "./dist/slot-wire-schema.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ontology-search/api-types": "workspace:*",
    "@ontology-search/core": "workspace:*",
    "@ontology-search/ontology": "workspace:*",
    "@ontology-search/sparql": "workspace:*",
    "sparqljs": "^3.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@types/node": "^25.7.0",
    "@types/sparqljs": "^3.1.12",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
