{
  "name": "@ontology-search/graphql-ir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Slot ↔ GraphQL codec — serialize SearchSlots to a GraphQL query, parse a GraphQL query back to slots, and validate both. A standalone, graphql-js-pinned contract layer over the slot IR.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ontology-search/core": "workspace:*",
    "@ontology-search/slots": "workspace:*",
    "graphql": "^16.14.2"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@types/node": "^25.7.0",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
