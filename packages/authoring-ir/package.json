{
  "name": "@ontology-search/authoring-ir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The authoring IR — the structured 'scene slots' the LLM fills to author an OpenSCENARIO scenario. Pure types plus the Zod wire schema; the authoring-side security boundary (the LLM emits only this IR, never raw .xosc).",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./scene": {
      "types": "./src/scene.ts",
      "import": "./dist/scene.js",
      "default": "./dist/scene.js"
    },
    "./scene-wire-schema": {
      "types": "./src/scene-wire-schema.ts",
      "import": "./dist/scene-wire-schema.js",
      "default": "./dist/scene-wire-schema.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc -p tsconfig.test.json",
    "clean": "rimraf dist",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "3.2.4",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
