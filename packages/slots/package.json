{
  "name": "@ontology-search/slots",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The slot IR — the structured intermediate representation the LLM fills and the compiler reads. Pure types plus the Zod wire schema; the system's central contract.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./slots": {
      "types": "./src/slots.ts",
      "import": "./dist/slots.js",
      "default": "./dist/slots.js"
    },
    "./slot-wire-schema": {
      "types": "./src/slot-wire-schema.ts",
      "import": "./dist/slot-wire-schema.js",
      "default": "./dist/slot-wire-schema.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc -p tsconfig.test.json",
    "clean": "rimraf dist",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "3.2.4",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
