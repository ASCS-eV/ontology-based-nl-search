{
  "name": "@ontology-search/authoring-wasm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The in-process OpenSCENARIO WASM engine — RA Consulting's openscenario.api.test C++ API (Apache-2.0) compiled to WebAssembly with a thin embind wrapper. Authors, serializes and validates OpenSCENARIO 1.3 in-process, mirroring Oxigraph WASM in packages/sparql.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "src",
    "wasm"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:wasm": "node native/build.mjs",
    "verify:checksum": "node native/verify-checksum.mjs",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "check-types:tests": "tsc -p tsconfig.test.json",
    "clean": "rimraf dist",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "3.2.4",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
