{
  "name": "@ontology-search/sparql",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./policy": {
      "types": "./src/policy.ts",
      "import": "./dist/policy.js",
      "default": "./dist/policy.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ontology-search/core": "workspace:*",
    "oxigraph": "^0.4.0-alpha.8",
    "sparqljs": "^3.7.4"
  },
  "devDependencies": {
    "@ontology-search/typescript-config": "workspace:*",
    "@types/node": "^25.7.0",
    "@types/sparqljs": "^3.1.12",
    "rimraf": "^6.0.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.0"
  }
}
