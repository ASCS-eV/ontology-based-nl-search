    skos:prefLabel "mwyExit"@en ;
    skos:altLabel "motorway exit"@en ;
    skos:altLabel "Autobahnausfahrt"@de ;
    skos:broader nlsearch:exitLane ;
    nlsearch:ontologyProperty hdmap:laneTypes ;
    nlsearch:ontologyValue "mwyExit" .

