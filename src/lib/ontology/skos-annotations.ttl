    skos:prefLabel "Lanelet"@en ;
    skos:altLabel "Lanelet2"@en ;
    skos:altLabel "lanelet"@en ;
    skos:altLabel "lanelet2"@en ;
    skos:definition "Lanelet map format for autonomous driving."@en ;
    nlsearch:ontologyProperty hdmap:formatType ;
    nlsearch:ontologyValue "Lanelet" .

nlsearch:road2sim a skos:Concept ;
