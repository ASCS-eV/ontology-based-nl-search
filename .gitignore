# Dependencies
node_modules/

# Build
dist/
.next/
out/
tsconfig.tsbuildinfo

# Native WASM build scratch (packages/authoring-wasm/native/build.mjs)
.build/
# Environment
.env.local
.env.*.local

# Ontology cache (fetched at runtime)
.ontology-cache/

# Generated ontology sources config (use ontology-sources.example.json as template)
ontology-sources.json

# IDE
.vscode/
.idea/

# Local working scratchpad — audits, refactor plans, etc.
# Tracks transitional state we do not want in repo history.
.playground/
plans/

# Claude Code working directory (scheduled-task lockfile, etc.)
.claude/

# OS
.DS_Store
Thumbs.db

# Debug
npm-debug.log*

# Test output
coverage/
playwright-report/
test-results/

# Evaluation results (generated by scripts/test-1000-queries.mjs)
scripts/eval/*.json

# Turbo
.turbo/

# VitePress
apps/docs/.vitepress/cache/
apps/docs/.vitepress/dist/
