{
  "name": "ontology-based-nl-search",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "node scripts/clean-ports.mjs && node scripts/dev.mjs",
    "dev:api": "node scripts/clean-ports.mjs 3003 && pnpm run build && pnpm --filter @ontology-search/api dev",
    "dev:web": "node scripts/clean-ports.mjs 5174 && turbo run dev --filter=@ontology-search/web",
    "test": "turbo run test --concurrency=2",
    "coverage": "turbo run coverage",
    "test:scripts": "node --test \"scripts/*.test.mjs\"",
    "test:e2e": "turbo run test:e2e",
    "eval:retrieval": "pnpm --filter @ontology-search/testing exec vitest run src/eval/__tests__/retrieval-eval.test.ts --reporter=basic",
    "check-types": "turbo run check-types",
    "check:test-types": "turbo run check-types:tests",
    "check:layers": "node scripts/check-layers.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "turbo run check-types && pnpm run check:test-types && pnpm run check:layers && turbo run test --concurrency=2 && pnpm run test:scripts && pnpm run lint && pnpm run format:check",
    "clean": "turbo run clean",
    "clean:ports": "node scripts/clean-ports.mjs",
    "check:setup": "node scripts/check-ontology-sources.mjs --strict",
    "postinstall": "node scripts/check-ontology-sources.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@ontology-search/eslint-config": "workspace:*",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.59.2"
  }
}
