# Environment Configuration
# Copy this file to .env.local and fill in the values

# --- SPARQL Store ---
# Mode: "memory" (Oxigraph WASM in-process) or "remote" (external SPARQL endpoint)
SPARQL_MODE=memory

# Remote SPARQL endpoint (only used when SPARQL_MODE=remote)
SPARQL_ENDPOINT=http://localhost:3030/envited/sparql

# --- LLM Provider (Vercel AI SDK) ---
# Provider: "openai", "copilot", "ollama"
AI_PROVIDER=copilot

# API Keys (set the one matching your provider)
OPENAI_API_KEY=
# For copilot provider: use your GitHub token (gh auth token)
GITHUB_TOKEN=

# For Ollama (local): base URL
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (provider-specific)
# openai: gpt-4o, gpt-4o-mini, etc.
# copilot: claude-sonnet-4, claude-opus-4.6, gpt-4o, etc.
# ollama: llama3, mistral, etc.
AI_MODEL=claude-opus-4.6

# --- Ontology ---
# GitHub repo for ontology source (fallback if submodule not present)
ONTOLOGY_REPO=ASCS-eV/ontology-management-base
ONTOLOGY_BRANCH=main
