# Environment Configuration
# Copy this file to .env.local and fill in the values

# --- SPARQL Store ---
# Mode: "memory" (Oxigraph WASM in-process) or "remote" (external SPARQL endpoint)
SPARQL_MODE=memory

# Remote SPARQL endpoint (only used when SPARQL_MODE=remote)
SPARQL_ENDPOINT=http://localhost:3030/envited/sparql

# --- LLM Provider (Vercel AI SDK) ---
# Provider: "openai", "anthropic", "google", "ollama"
AI_PROVIDER=openai

# API Keys (set the one matching your provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# For Ollama (local): base URL
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (provider-specific)
AI_MODEL=gpt-4o

# --- Ontology ---
# GitHub repo for ontology source
ONTOLOGY_REPO=ASCS-eV/ontology-management-base
ONTOLOGY_BRANCH=main
