# =============================================================================
# Environment Configuration — Ontology-Based NL Search
# =============================================================================
# Copy this file to .env.local to get started.
# Default config uses Ollama (free, local) — no API keys needed.
# Just run: ollama pull qwen3:8b
# =============================================================================

# --- SPARQL Store ---
# "memory" = Oxigraph WASM in-process (default, no setup needed)
# "remote" = external SPARQL endpoint (e.g., Apache Jena Fuseki)
SPARQL_MODE=memory

# Remote endpoint (only when SPARQL_MODE=remote)
# SPARQL_ENDPOINT=http://localhost:3030/envited/sparql

# --- LLM Provider ---
# "ollama"     = Local Ollama instance (free, no API key)
# "openai"     = OpenAI API (requires OPENAI_API_KEY)
# "anthropic"  = Anthropic API (requires ANTHROPIC_API_KEY)
# "claude-cli" = Claude CLI session (reads token from ~/.claude/.credentials.json, no key needed)
# "vibe-cli"   = Mistral via the `vibe` CLI (reads MISTRAL_API_KEY from ~/.vibe/.env; run `vibe --setup`)
# "copilot"    = GitHub Copilot via @github/copilot-sdk (requires GITHUB_TOKEN)
AI_PROVIDER=ollama

# --- Model ---
# This app requires models with TOOL CALLING support (function calling).
# Models without tool calling (e.g. qwen2.5-coder) will NOT work.
#
# ollama:     qwen3:8b (recommended), qwen3:4b (lighter), llama3.3 (70b only)
# openai:     gpt-4o, gpt-4o-mini
# anthropic:  claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# claude-cli: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# vibe-cli:   ministral-8b-latest (fast, ~15s; default-recommended);
#             mistral-medium-3.5 (slower ~90s but more rigorous at compound queries);
#             mistral-large-latest (any tool-calling Mistral model);
#             magistral-*-2509 (reasoning variants — slower, more accurate on hard mappings)
# copilot:    claude-sonnet-4.6, claude-haiku-4.5, gpt-4.1
AI_MODEL=qwen3:8b

# --- Ollama (default provider) ---
# Install: https://ollama.ai   (requires Ollama >= 0.3.0 for tool calling)
# Then pull the model: ollama pull qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- OpenAI (optional) ---
# OPENAI_API_KEY=sk-...

# --- Anthropic (optional, not needed for claude-cli) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub Copilot (only when AI_PROVIDER=copilot) ---
# Obtain via: gh auth token
# GITHUB_TOKEN=gho_...

# --- Mistral / vibe-cli (only when AI_PROVIDER=vibe-cli) ---
# No key needed here — `vibe --setup` stores MISTRAL_API_KEY in ~/.vibe/.env.
# Override the API base to point at a local model server if desired:
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# --- Ontology Source ---
# Fallback if submodules not initialized (git submodule update --init --recursive)
ONTOLOGY_REPO=ASCS-eV/ontology-management-base
ONTOLOGY_BRANCH=main

# Override the workspace root used by ontology source discovery (default:
# walks up from the package to find pnpm-workspace.yaml). Useful for tests
# that seed a temp workspace and for deployments that mount artifacts at
# a non-default path.
# ONTOLOGY_ROOT=/path/to/workspace

# Override the artifacts directory (default: the OMB submodule chain inside
# the workspace). Takes precedence over the default; manifest entries in
# ontology-sources.json win over both.
# ONTOLOGY_ARTIFACTS_PATH=/path/to/artifacts

# --- API ---
# HTTP port the API server listens on (default 3003).
# API_PORT=3003
# Maximum incoming request body size in bytes (default 65536 = 64 KB).
# API_MAX_BODY_BYTES=65536
# Maximum natural-language query length in characters (default 2000). Bounds the
# prompt sent to the LLM independently of the overall body-size limit.
# API_MAX_QUERY_CHARS=2000
# Comma-separated CORS origins (default "*"). MUST be set to the
# exact frontend origins in production — NODE_ENV=production + "*"
# fails fast at startup.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
# Token-bucket rate limit. RATE_LIMIT_RPS=0 (default) disables it
# entirely; set to a positive number to throttle. RATE_LIMIT_BURST
# is the maximum spike allowed above the average.
# RATE_LIMIT_RPS=0
# RATE_LIMIT_BURST=10
# Optional API key. Empty (default) leaves the API open — fine for local dev or
# when an upstream gateway handles auth. When set, every request except /health
# must send `Authorization: Bearer <key>` or `x-api-key: <key>`, else HTTP 401.
# API_KEY=
# Production fail-safe: with NODE_ENV=production the API refuses to start unless
# either API_KEY is set OR you explicitly opt into running open here (e.g. when
# a gateway authenticates upstream). Default false so a public deploy can't be
# left unauthenticated by accident.
# API_ALLOW_UNAUTHENTICATED=false

# --- SPARQL policy & networking ---
# Hard ceiling on the LIMIT clause the policy accepts (default 500).
# SPARQL_MAX_LIMIT=500
# Default LIMIT the compiler embeds in every emitted query (default 100).
# Must be ≤ SPARQL_MAX_LIMIT — startup fails fast otherwise.
# SPARQL_DEFAULT_LIMIT=100
# HTTP timeout for remote SPARQL endpoints in ms (default 30000).
# SPARQL_REMOTE_TIMEOUT_MS=30000
# In-memory query-result cache size and TTL.
# SPARQL_CACHE_SIZE=256
# SPARQL_CACHE_TTL_MS=300000

# --- SHACL validator ---
# Maximum number of per-(property, value, target-class) SHACL validation
# results retained in memory. The shapes graph is immutable for the
# process lifetime, but the value space is unbounded — this LRU bound
# caps memory under long-running servers. Default 1024.
# SHACL_CACHE_SIZE=1024

# --- LLM agent tuning ---
# Maximum tool-calling steps for the Vercel-SDK agent. With slot-filling,
# the LLM typically needs only one step (`submit_slots`); the default of 3
# leaves headroom for retries.
# LLM_MAX_AGENT_STEPS=3
# Sampling temperature passed to the LLM. Slot filling is an extraction
# task — `0` (greedy decoding, deterministic) is the right default for
# every provider. Honoured by openai/ollama/anthropic/claude-cli/vibe-cli;
# ignored by the Copilot SDK. Raise above 0 only when intentionally
# introducing variance (A/B tests, creative-task experiments).
# LLM_TEMPERATURE=0

# --- Reasoning / "thinking" mode ---
# Hidden chain-of-thought before the answer. Trades latency for accuracy
# on hard disambiguation. HOW you enable it depends on the provider:
#
#   * Anthropic / claude-cli:
#       Set LLM_THINKING_BUDGET to a positive token count (Anthropic
#       recommends ≥ 1024). Off by default (0 = same speed as a regular
#       call). Wall-clock typically goes 2–5× when enabled.
#
#   * Mistral / vibe-cli:
#       Reasoning is a SEPARATE model family — change AI_MODEL to a
#       `magistral-*` variant (e.g. `magistral-medium-2509`,
#       `magistral-small-2509`). LLM_THINKING_BUDGET is ignored.
#
#   * OpenAI:
#       The `o1` and `o4` series are reasoning-by-design — pick the
#       model in AI_MODEL. The budget is fixed by the model, not the
#       caller. LLM_THINKING_BUDGET is ignored.
#
#   * Ollama / Copilot / local:
#       Not supported — LLM_THINKING_BUDGET is ignored.
#
# For our slot-filling task, the gain from reasoning is small (5–10% on
# edge cases) and the latency cost is large. Leave at 0 unless an
# experiment specifically needs it.
# LLM_THINKING_BUDGET=0

# --- Logging ---
# debug | info | warn | error | silent (default: debug in dev, info in
# production, silent in test).
# LOG_LEVEL=debug
